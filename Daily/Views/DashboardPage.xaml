<Page
    x:Class="Daily.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    d:DesignHeight="650" d:DesignWidth="900"
    Title="Dashboard">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24">

            <!-- Header -->
            <TextBlock
                Text="{DynamicResource Dashboard_Title}"
                FontSize="28"
                FontWeight="SemiBold"
                Margin="0,0,0,20" />

            <!-- Input Stats Cards -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Mouse Clicks -->
                <ui:Card Grid.Column="0" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="CursorClick24" FontSize="22" Margin="0,0,8,0" />
                            <TextBlock Text="{DynamicResource Dashboard_MouseClicks}" FontSize="14" VerticalAlignment="Center" Opacity="0.7" />
                        </StackPanel>
                        <TextBlock
                            Text="{Binding Statistics.TotalMouseClicks, StringFormat={}{0:N0}}"
                            FontSize="32"
                            FontWeight="Bold" />
                    </StackPanel>
                </ui:Card>

                <!-- Keyboard Presses -->
                <ui:Card Grid.Column="2" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="Keyboard24" FontSize="22" Margin="0,0,8,0" />
                            <TextBlock Text="{DynamicResource Dashboard_KeyPresses}" FontSize="14" VerticalAlignment="Center" Opacity="0.7" />
                        </StackPanel>
                        <TextBlock
                            Text="{Binding Statistics.TotalKeyboardPresses, StringFormat={}{0:N0}}"
                            FontSize="32"
                            FontWeight="Bold" />
                    </StackPanel>
                </ui:Card>

                <!-- Total Apps Tracked -->
                <ui:Card Grid.Column="4" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="AppsList24" FontSize="22" Margin="0,0,8,0" />
                            <TextBlock Text="{DynamicResource Dashboard_AppsTracked}" FontSize="14" VerticalAlignment="Center" Opacity="0.7" />
                        </StackPanel>
                        <TextBlock
                            Text="{Binding Statistics.AppUsages.Count, StringFormat={}{0:N0}}"
                            FontSize="32"
                            FontWeight="Bold" />
                    </StackPanel>
                </ui:Card>
            </Grid>

            <!-- App Usage Table -->
            <ui:Card Padding="0">
                <StackPanel>
                    <TextBlock
                        Text="{DynamicResource Dashboard_AppUsage}"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Margin="20,16,20,12" />

                    <DataGrid
                        ItemsSource="{Binding SortedAppUsages}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        IsReadOnly="False"
                        SelectionMode="Single"
                        BorderThickness="0"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        Margin="4,0,4,8"
                        RowHeight="40">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Header="{DynamicResource Col_Application}"
                                Binding="{Binding AppName}"
                                Width="*"
                                MinWidth="150"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Header="{DynamicResource Col_Process}"
                                Binding="{Binding ProcessName}"
                                Width="130"
                                IsReadOnly="True" />
                            <!-- Category: editable ComboBox -->
                            <DataGridTemplateColumn
                                Header="{DynamicResource Col_Category}"
                                Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Text="{Binding Category}"
                                            VerticalAlignment="Center"
                                            Margin="4,0" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox
                                            ItemsSource="{Binding DataContext.CategoryList,
                                                RelativeSource={RelativeSource AncestorType=Page}}"
                                            SelectedItem="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                            IsDropDownOpen="True" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn
                                Header="{DynamicResource Col_TotalTime}"
                                Binding="{Binding FormattedTime}"
                                Width="110"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Header="{DynamicResource Col_LastActive}"
                                Binding="{Binding LastActiveTime, StringFormat={}{0:HH:mm:ss}}"
                                Width="110"
                                IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </ui:Card>

        </StackPanel>
    </ScrollViewer>
</Page>
