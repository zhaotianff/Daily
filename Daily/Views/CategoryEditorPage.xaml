<Page
    x:Class="Daily.Views.CategoryEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    d:DesignHeight="650" d:DesignWidth="900"
    Title="Category Editor">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,16,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock
                Grid.Row="0"
                Text="{DynamicResource CategoryEditor_Title}"
                FontSize="28"
                FontWeight="SemiBold"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Margin="0,0,0,4" />
            <TextBlock
                Grid.Row="1"
                Text="{DynamicResource CategoryEditor_Subtitle}"
                FontSize="13"
                Opacity="0.6"
                Margin="0,0,0,16" />

            <!-- Search + Add bar -->
            <ui:Card Grid.Row="2" Padding="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <ui:TextBox
                        Grid.Column="0"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="{DynamicResource CategoryEditor_Search}"
                        Icon="{ui:SymbolIcon Symbol=Search24}" />

                    <!-- New process name input -->
                    <ui:TextBox
                        Grid.Column="2"
                        Text="{Binding NewProcessName, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="{DynamicResource CategoryEditor_ProcessName}" />

                    <!-- New category dropdown -->
                    <ComboBox
                        Grid.Column="4"
                        ItemsSource="{Binding CategoryList}"
                        SelectedItem="{Binding NewCategory, Mode=TwoWay}"
                        MinWidth="160" />

                    <!-- Add button -->
                    <ui:Button
                        Grid.Column="6"
                        Content="{DynamicResource CategoryEditor_Add}"
                        Command="{Binding AddEntryCommand}"
                        Appearance="Primary" />
                </Grid>
            </ui:Card>

            <!-- Mappings DataGrid -->
            <ui:Card Grid.Row="3" Padding="0" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,12,20,8">
                        <TextBlock
                            Text="{DynamicResource CategoryEditor_MappingsTitle}"
                            FontSize="16"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center" />
                        <ui:Button
                            Margin="12,0,0,0"
                            Content="{DynamicResource CategoryEditor_Delete}"
                            Command="{Binding DeleteSelectedCommand}"
                            Appearance="Danger"
                            IsEnabled="{Binding CanDeleteSelected}"
                            ToolTip="{DynamicResource CategoryEditor_DeleteTooltip}" />
                    </StackPanel>

                    <DataGrid
                        Grid.Row="1"
                        x:Name="MappingsGrid"
                        ItemsSource="{Binding Entries}"
                        SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        IsReadOnly="False"
                        SelectionMode="Single"
                        BorderThickness="0"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        Margin="4,0,4,8"
                        RowHeight="38"
                        MaxHeight="460">
                        <DataGrid.Columns>
                            <!-- Process Name (read-only) -->
                            <DataGridTextColumn
                                Header="{DynamicResource Col_Process}"
                                Binding="{Binding ProcessName}"
                                Width="*"
                                MinWidth="160"
                                IsReadOnly="True" />

                            <!-- Category (ComboBox) -->
                            <DataGridTemplateColumn
                                Header="{DynamicResource Col_Category}"
                                Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Text="{Binding Category}"
                                            VerticalAlignment="Center"
                                            Margin="4,0" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox
                                            ItemsSource="{Binding DataContext.CategoryList,
                                                RelativeSource={RelativeSource AncestorType=Page}}"
                                            SelectedItem="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                            IsDropDownOpen="True" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Source indicator (Built-in vs Custom) -->
                            <DataGridTemplateColumn
                                Header="{DynamicResource CategoryEditor_Source}"
                                Width="110"
                                IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center" Margin="4,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"
                                                            Value="{DynamicResource CategoryEditor_BuiltIn}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUserOverride}" Value="True">
                                                            <Setter Property="Text"
                                                                    Value="{DynamicResource CategoryEditor_Custom}" />
                                                            <Setter Property="Foreground" Value="#4F8DF9" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </ui:Card>

            <!-- Status bar -->
            <TextBlock
                Grid.Row="4"
                Text="{Binding StatusMessage}"
                FontSize="12"
                Opacity="0.6"
                Margin="4,0" />
        </Grid>
    </ScrollViewer>
</Page>

